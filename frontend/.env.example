# Browser-visible API base URL. API paths are appended to this value, for example /api/v1/tasks.
NEXT_PUBLIC_API_URL=https://arm.delous.ru

# Enable the in-memory backend used by app/lib/mock-api.ts.
NEXT_PUBLIC_USE_MOCK_API=false

# Optional key for real Web Push subscriptions.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
